# Upstash Redis Configuration (KV)
# You can use either the new KV_* variables or the legacy UPSTASH_* variables
# Get these from your Upstash console: https://console.upstash.io/

# Recommended (Upstash Vercel Integration):
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your-redis-token
KV_REST_API_READ_ONLY_TOKEN=your-read-only-token

# Alternative (Legacy):
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Redis URL (for traditional Redis clients):
REDIS_URL=redis://default:your-password@your-redis-instance.upstash.io:6379
KV_URL=redis://default:your-password@your-redis-instance.upstash.io:6379

# DeepL API Configuration
# Get your API key from: https://www.deepl.com/pro-api
DEEPL_API_KEY=your-deepl-api-key

# Site Configuration
SITE_URL=https://grangoty.vercel.app

# Optional: Scraping Configuration
SCRAPER_USER_AGENT=GRANgoTY/1.0 (Grant Aggregator for NGOs)
SCRAPER_RATE_LIMIT=10
